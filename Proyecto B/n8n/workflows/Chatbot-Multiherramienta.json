        "jsCode": "// 1. Obtenemos el texto plano que ha generado la IA\nconst aiOutput = $input.first().json.content;\n\n// 2. Obtenemos los datos del usuario del nodo 'Edit Fields'\nconst userData = $('Edit Fields').first().json.message;\n\n// 3. Devolvemos la estructura final directa para la Base de Datos y Telegram\nreturn {\n  json: {\n    chat_id: userData.chat.id,\n    username: userData.chat.first_name,\n    mensajeUser: userData.text,\n    mensaje: aiOutput, // Pasamos el texto de la IA directamente aquí\n    fecha: new Date().toISOString()\n  }\n};"
